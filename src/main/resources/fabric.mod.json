{
	"schemaVersion": 1,
	"id": "guildbridge",
	"version": "${version}",
	"name": "Guild Bridge",
	"description": "An easy to use Guild Bridge Fabric Mod",
	"authors": [
		"zapp908"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/guildbridge/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"at.zapp908.guildbridge.GuildBridge"
		],
		"fabric-datagen": [
			"at.zapp908.guildbridge.GuildBridgeDataGenerator"
		],
		"client": [
			"at.zapp908.guildbridge.GuildBridgeClient"
		]
	},
	"mixins": [
		"guildbridge.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
